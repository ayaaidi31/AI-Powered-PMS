<mxCell id="s54" value="AIScribeService encapsulates the RAG orchestration (history retrieval, grounded prompt, and LLM synthesis) behind a dedicated control object." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=6;fontSize=9;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="200" y="742" width="400" height="58" as="geometry"/></mxCell>
<mxCell id="s55" value="Privacy: the doctor's raw notes are kept for audit. If voice capture is used, the audio is transcribed and then discarded — no recording is persisted." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=6;fontSize=9;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="640" y="742" width="400" height="58" as="geometry"/></mxCell>
<mxCell id="s56" value="Immutability: on approve(), the ConsultationReport is locked against further edits and written to the audit trail (F9)." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=6;fontSize=9;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="1080" y="742" width="380" height="58" as="geometry"/></mxCell>
