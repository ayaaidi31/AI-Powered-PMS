<mxCell id="f1" value="Database — Record Lifecycle of a Patient Visit" style="text;html=1;align=left;fontSize=16;fontStyle=1;fontColor=#2c3e50;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="26" as="geometry"/></mxCell>
<mxCell id="f2" value="Which tables are written at each stage of care. The read-only support stores below are never written by the workflow." style="text;html=1;align=left;fontSize=10;fontStyle=2;fontColor=#777;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="1000" height="18" as="geometry"/></mxCell>
