<mxCell id="cat_h" value="Reference catalogs  (read-only, official German code sets)" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#1e88e5;strokeColor=#1e88e5;fontColor=#fff;fontStyle=1;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="380" width="560" height="26" as="geometry"/></mxCell>
<mxCell id="cat" value="•  icd_10_gm&amp;nbsp;&amp;nbsp;&amp;nbsp;•  ebm_catalog&amp;nbsp;&amp;nbsp;&amp;nbsp;•  goae_catalog&amp;nbsp;&amp;nbsp;&amp;nbsp;•  medication_pzn" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontColor=#333;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="406" width="560" height="70" as="geometry"/></mxCell>
<mxCell id="rag" value="RAG knowledge base — pgvector&amp;#10;langchain_pg_embedding&amp;#10;(AWMF guidelines · BGE 1024-dim)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#e0f2f1;strokeColor=#00897b;fontColor=#00695c;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="720" y="372" width="340" height="110" as="geometry"/></mxCell>
<mxCell id="f6" value="ICD-10 / PZN validate conditions &amp;amp; medications" style="endArrow=open;endFill=1;html=1;dashed=1;rounded=1;strokeColor=#78909c;fontSize=9;fontColor=#607d8b;" edge="1" parent="1" source="cat" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="f7" value="EBM / GOÄ validate billing codes" style="endArrow=open;endFill=1;html=1;dashed=1;rounded=1;strokeColor=#78909c;fontSize=9;fontColor=#607d8b;" edge="1" parent="1" source="cat" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="f8" value="grounds AI decision support (read-only, F13)" style="endArrow=open;endFill=1;html=1;dashed=1;rounded=1;strokeColor=#78909c;fontSize=9;fontColor=#607d8b;" edge="1" parent="1" source="rag" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="f9" value="Design rules baked into the schema:" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#444;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="520" width="320" height="16" as="geometry"/></mxCell>
<mxCell id="f10" value="•  Clinical rows: no cascade delete — soft delete (deleted_at) for legal retention (§630f BGB)" style="text;html=1;fontSize=10;fontColor=#666;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="542" width="1020" height="16" as="geometry"/></mxCell>
<mxCell id="f11" value="•  Invoices: gapless invoice_number; a cancellation is a storno row, never a deletion (§14 UStG)" style="text;html=1;fontSize=10;fontColor=#666;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="560" width="1020" height="16" as="geometry"/></mxCell>
<mxCell id="f12" value="•  Money stored as integer cents; reports become immutable once approved" style="text;html=1;fontSize=10;fontColor=#666;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="578" width="1020" height="16" as="geometry"/></mxCell>
</root></mxGraphModel></diagram></mxfile>
