# Environment variables. Copy the ones that apply into .env.local (git-ignored).

# Database connection string.
DATABASE_URL=postgres://user:password@host/db

# Secret used to sign the session tokens; a long random string.
AUTH_SECRET=

# API key for the language model behind the AI features.
MISTRAL_API_KEY=

# Outbound email (check-in codes, report and invoice notices, reminders).
# Optional: without it the application runs normally and codes are shown in the
# interface rather than emailed.
RESEND_API_KEY=

# Sender address for outbound email. When empty, the provider's sandbox sender is
# used, which reaches only the account owner's address; a verified domain is
# needed to send to other recipients.
CHECK_IN_EMAIL_FROM=

# Base URL of the application, used for links in emails and the check-in QR
# poster. Falls back to http://localhost:3000 during local development.
APP_URL=http://localhost:3000

# Shared secret for the daily reminder endpoint (/api/cron/reminders). When set,
# the request must carry it as a bearer token; when empty the check is skipped
# (development only).
CRON_SECRET=

# Optional override for the clinic timezone. The server defaults to Europe/Berlin
# (set at startup in instrumentation.ts); set this only for a clinic in another
# zone. Affects office hours, the voice assistant, and invoice numbering.
TZ=
