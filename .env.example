# Copy the keys you need into .env.local (which is git-ignored).

# ── Database (required) ──
DATABASE_URL=postgres://user:password@host/db

# ── Auth (required) ── long random string used to sign session JWTs
AUTH_SECRET=change-me-to-a-long-random-string

# ── LLM (AI features) ──
MISTRAL_API_KEY=

# ── Email: self check-in codes (Feature 3) ──
# Get a free key at https://resend.com. Without it, booking still works and the
# code is shown in-app; it just isn't emailed.
RESEND_API_KEY=
# Sender address. Defaults to Resend's shared sandbox sender, which only delivers
# to your OWN Resend account email. To email real patients, verify a domain in
# Resend and set e.g. "AI-PMS Clinic <noreply@your-domain.com>".
CHECK_IN_EMAIL_FROM=
# Base URL used in emails and the check-in QR poster. Set to your deployed domain
# in production; defaults to http://localhost:3000 for local testing.
APP_URL=http://localhost:3000
